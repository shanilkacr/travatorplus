{
  "name": "travator",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check:colors": "node scripts/check-colors.mjs",
    "db:generate": "pnpm --filter @travator/api db:generate",
    "db:migrate": "pnpm --filter @travator/api db:migrate",
    "db:seed": "pnpm --filter @travator/api db:seed",
    "deploy:api": "pnpm --filter @travator/api deploy:worker"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
