# ─────────────────────────────────────────────────────────────
# Travator environment. Copy to .env and fill in.
# ─────────────────────────────────────────────────────────────

# ── LLM (agent layer) ────────────────────────────────────────
# Provider + default model for the conversational agent.
LLM_PROVIDER=anthropic            # anthropic | openai | google
LLM_MODEL=claude-sonnet-5         # e.g. claude-sonnet-5, gpt-4.1
# Cheaper model routed for extraction/parsing tasks (taskModel map).
TASK_LLM_PROVIDER=anthropic
TASK_LLM_MODEL=claude-haiku-4-5-20251001

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Embeddings ───────────────────────────────────────────────
# mock = deterministic hash-based vectors (no network, good for dev).
EMBEDDINGS_PROVIDER=mock          # mock | voyage | openai
EMBEDDINGS_MODEL=voyage-3
VOYAGE_API_KEY=
EMBEDDINGS_DIM=1024

# ── Datastores ───────────────────────────────────────────────
DATABASE_URL=postgres://travator:travator@localhost:5432/travator
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=dev-only-change-me-please-32-chars-min
JWT_ISSUER=travator
OTP_TTL_SECONDS=600

# ── API server ───────────────────────────────────────────────
API_PORT=8787
API_PUBLIC_URL=http://localhost:8787
WEB_ORIGIN=http://localhost:3000

# ── Cloudflare Workers (production API) ──────────────────────
# Deploy: cd apps/api && pnpm deploy:worker
# Set secrets: wrangler secret put DATABASE_URL (Supabase pooler URL, port 6543)
#              wrangler secret put ANTHROPIC_API_KEY
#              wrangler secret put JWT_SECRET
# Update WEB_ORIGIN in apps/api/wrangler.toml [vars] to your Vercel URL.
# Then set NEXT_PUBLIC_API_URL=https://travator-api.<your-subdomain>.workers.dev

# ── Web app ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8787
# Calendly embed for /book-a-call. Defaults to shanilka/30min when unset.
NEXT_PUBLIC_CAL_COM_URL=https://calendly.com/shanilka/30min

# ── Currency display ─────────────────────────────────────────
# Fixed FX for USD->LKR display (MVP has no live rates).
USD_TO_LKR=305

# ── Web (Vercel) ───────────────────────────────────────────
# Canonical site origin. Drives metadata, canonical URLs, sitemap and JSON-LD.
# Falls back to the Vercel production URL, then https://travator.com
NEXT_PUBLIC_SITE_URL=https://travator.com

# Scheduling link used by the article CTA and the in-chat booking card.
# Leave unset to fall back to the internal /book-a-call page.
NEXT_PUBLIC_BOOKING_URL=https://calendly.com/shanilka/30min
