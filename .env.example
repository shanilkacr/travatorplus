# ─────────────────────────────────────────────────────────────
# Travator environment. Copy to .env and fill in.
# ─────────────────────────────────────────────────────────────

# ── LLM (agent layer) ────────────────────────────────────────
# Provider + default model for the conversational agent.
LLM_PROVIDER=anthropic            # anthropic | openai | google
LLM_MODEL=claude-sonnet-5         # e.g. claude-sonnet-5, gpt-4.1
# Cheaper model routed for extraction/parsing tasks (taskModel map).
TASK_LLM_PROVIDER=anthropic
TASK_LLM_MODEL=claude-haiku-4-5-20251001

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Embeddings ───────────────────────────────────────────────
# mock = deterministic hash-based vectors (no network, good for dev).
EMBEDDINGS_PROVIDER=mock          # mock | voyage | openai
EMBEDDINGS_MODEL=voyage-3
VOYAGE_API_KEY=
EMBEDDINGS_DIM=1024

# ── Datastores ───────────────────────────────────────────────
DATABASE_URL=postgres://travator:travator@localhost:5432/travator
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────
JWT_SECRET=dev-only-change-me-please-32-chars-min
JWT_ISSUER=travator
OTP_TTL_SECONDS=600

# ── API server ───────────────────────────────────────────────
API_PORT=8787
API_PUBLIC_URL=http://localhost:8787
WEB_ORIGIN=http://localhost:3000

# ── Web app ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8787
# Calendly embed for /book-a-call. Defaults to shanilka/30min when unset.
NEXT_PUBLIC_CAL_COM_URL=https://calendly.com/shanilka/30min

# ── Currency display ─────────────────────────────────────────
# Fixed FX for USD->LKR display (MVP has no live rates).
USD_TO_LKR=305
